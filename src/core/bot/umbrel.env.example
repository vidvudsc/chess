LICHESS_BOT_TOKEN=replace_with_your_bot_token
LICHESS_BOT_BACKEND=classic
# Set to experimental to run the HCE experiment lane on Umbrel.
# LICHESS_BOT_BACKEND=experimental
# Set to nn to run the neural evaluator on Umbrel.
# LICHESS_BOT_BACKEND=nn
# CHESS_NN_MODEL=/home/umbrel/vidvuds-lab/chess/chessbot/shared/nn_eval.bin
LICHESS_BOT_ACCEPT_BOTS=1
LICHESS_BOT_ACCEPT_HUMANS=1
# Optional incoming challenge filter. Empty accepts all non-correspondence standard games.
# Use blitz,rapid while tuning if bullet/ultraBullet are hurting rating signal.
# LICHESS_BOT_ACCEPT_SPEEDS=blitz,rapid
LICHESS_BOT_MAX_GAMES=4
LICHESS_BOT_MAX_BOT_GAMES=3
LICHESS_BOT_MAX_HUMAN_GAMES=1
# Leave empty to only accept incoming challenges. Example safe outgoing setup.
# 1+1 adds bullet without the worst 1+0 flag/latency noise.
# LICHESS_BOT_AUTO_CHALLENGES=1+1,2+1,3+2,5+3,10+0
LICHESS_BOT_AUTO_CHALLENGE_RATED=0
LICHESS_BOT_PAIR_POLL_SECONDS=60
LICHESS_BOT_MIN_CHALLENGE_GAP_SECONDS=300
LICHESS_BOT_MAX_OUTGOING_CHALLENGES_PER_HOUR=6
LICHESS_BOT_ONLINE_BOT_LIMIT=100
# Optional cooldown after service restart before sending outgoing challenges.
# LICHESS_BOT_INITIAL_PAIR_DELAY_SECONDS=300
LICHESS_BOT_LOG_MAX_MB=20
LICHESS_BOT_LOG_KEEP_FILES=5
