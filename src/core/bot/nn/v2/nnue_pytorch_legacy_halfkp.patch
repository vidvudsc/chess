@@ -19,0 +20,30 @@ using namespace chess;
+// HalfKP layout used by this engine. Black's perspective is mirrored
+// vertically and kings are omitted from the active feature list.
+struct LegacyHalfKPExtractor: IFeatureExtractor {
+    static constexpr int INPUTS = 64 * 10 * 64;
+    static constexpr int MAX_ACTIVE_FEATURES = 30;
+
+    int inputs() const override { return INPUTS; }
+    int max_active_features() const override { return MAX_ACTIVE_FEATURES; }
+
+    std::pair<int, int> fill_features_sparse(const TrainingDataEntry& e,
+                                             int* features,
+                                             Color color) const override {
+        auto king_sq = e.pos.kingSquare(color);
+        if (color == Color::Black)
+            king_sq = king_sq.flippedVertically();
+
+        int written = 0;
+        for (Square sq : e.pos.piecesBB())
+        {
+            const auto piece = e.pos.pieceAt(sq);
+            if (piece.type() == PieceType::King)
+                continue;
+            if (color == Color::Black)
+                sq = sq.flippedVertically();
+            const int plane = ordinal(piece.type()) + (piece.color() == color ? 0 : 5);
+            features[written++] = (ordinal(king_sq) * 10 + plane) * 64 + ordinal(sq);
+        }
+        return {written, INPUTS};
+    }
+};
@@ -351,0 +382,2 @@ struct ComposedFeatureExtractor: IFeatureExtractor {
